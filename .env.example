# Environment Variables
# Copy this file to .env and fill in the values

# Database connection URL
DATABASE_URL=postgresql://user:password@localhost:5432/construction

# Secret key for session/JWT signing (use a strong random value in production)
SECRET_KEY=your-secret-key-here-change-in-production

# Redis connection URL for task queue
REDIS_URL=redis://localhost:6379/0

# Email configuration
# EMAIL_PROVIDER options: resend | inmemory
EMAIL_PROVIDER=resend
# Resend settings (used when EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_xxx_replace_me
FROM_EMAIL=invites@yourdomain.com
APP_BASE_URL=http://localhost:3000

# Flask configuration
FLASK_DEBUG=false
FLASK_ENV=development
